# 请将此文件复制，并命名为 .env，修改其中的配置项后保存

# JWT 签名密钥，生产环境请替换为随机字符串
JWT_SECRET=dev-secret-please-change-in-production

# 古文岛 Cookie（聊天室功能依赖，可留空）
GUWENDAO_COOKIE=

# 管理后台日志最大条数（可选，默认 500）
MAX_LOGS=500

# 站外 SMTP 发信配置（仅在需要给站外邮箱发信时填写）
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM_ADDRESS=
SMTP_FROM_NAME=平渹网
